---
// 1. 保持你最原始的 Props 定义，一个字都没改
interface Props {
  title: string;
  description: string;
  href: string;
  tag?: string;
}

const { title, description, href, tag } = Astro.props;
---

<li
  class="group list-none relative rounded-2xl border border-white/10 bg-slate-950/40 p-6 backdrop-blur-xl transition-all duration-300 hover:border-emerald-500/40 hover:bg-slate-900/40 hover:-translate-y-1 hover:shadow-2xl hover:shadow-emerald-500/5"
>
  <a href={href} class="block h-full no-underline">
    {
      tag && (
        <div class="flex items-center gap-2 text-xs font-mono font-medium text-emerald-400 mb-3">
          <span class="w-1 h-1 rounded-full bg-emerald-400 animate-pulse" />
          blog → {tag}
        </div>
      )
    }

    <h3
      class="text-lg font-bold text-slate-100 transition-colors duration-300 group-hover:text-white"
    >
      {title}
    </h3>

    <p class="text-sm text-slate-400 mt-3 leading-relaxed line-clamp-2">
      {description}
    </p>
  </a>
</li>
