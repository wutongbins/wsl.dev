---
// src/pages/category/[tag].astro
import BaseLayout from "../../layouts/BaseLayout.astro";
import Card from "../../components/Card.astro";
import { getCollection, type CollectionEntry } from "astro:content";

// 🚀 核心：告诉 Astro 有多少个分类，需要生成多少个 /category/[tag] 页面
export async function getStaticPaths() {
  const allPosts = await getCollection("blog");

  // 拿到所有不重复的标签
  const allTags = [...new Set(allPosts.flatMap((post) => post.data.tags))];

  // 遍历每个标签，过滤出属于它的文章，然后当做 props 传给页面
  return allTags.map((tag) => {
    const filteredPosts = allPosts.filter((post) =>
      post.data.tags.includes(tag),
    );
    return {
      params: { tag },
      props: { posts: filteredPosts },
    };
  });
}

interface Props {
  posts: CollectionEntry<"blog">[];
}

const { tag } = Astro.params;
const { posts } = Astro.props;

// 按时间对该分类下的文章排序
const sortedPosts = posts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<BaseLayout title={`分类: ${tag}`}>
  <div class="mb-8">
    <a
      href="/"
      class="text-sm text-gray-500 hover:text-indigo-400 transition-colors"
      >← 返回所有分类</a
    >
    <h1 class="text-3xl font-extrabold text-white mt-4 flex items-center gap-2">
      <span class="w-3 h-3 rounded-full bg-indigo-500"></span>
      正在浏览 #{tag} 目录下的文章
    </h1>
  </div>

  <div class="grid gap-6 sm:grid-cols-2 w-full">
    {
      sortedPosts.map((post) => (
        <Card
          title={post.data.title}
          description={post.data.description}
          href={`/posts/${post.id}`}
          tag={post.data.tags[0]}
        />
      ))
    }
  </div>
</BaseLayout>
