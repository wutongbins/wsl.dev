---
// src/pages/index.astro
import BaseLayout from "../layouts/BaseLayout.astro";
import Card from "../components/Card.astro";
import { getCollection } from "astro:content";

// 1. 捞出所有文章并按时间排序
const allPosts = await getCollection("blog");
const sortedPosts = allPosts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

// 2. 自动提取所有不重复的标签（分类）
const allTags = [...new Set(allPosts.flatMap((post) => post.data.tags))];
---

<BaseLayout title="知识库工作台">
  <div
    class="flex flex-col md:flex-row gap-8 min-h-[70vh] relative items-start"
  >
    <aside
      class="w-full md:w-64 shrink-0 bg-gray-900/40 border border-gray-800 p-4 rounded-2xl md:sticky md:top-24"
    >
      <h2
        class="text-xs font-semibold uppercase tracking-wider text-gray-500 mb-4 px-2"
      >
        知识库大纲
      </h2>
      <nav class="space-y-1">
        {
          allTags.map((tag) => {
            const count = allPosts.filter((post) =>
              post.data.tags.includes(tag),
            ).length;
            return (
              <a
                href={`#category-${tag}`}
                class="flex items-center justify-between px-3 py-2.5 rounded-xl text-sm font-medium text-gray-400 hover:text-indigo-400 hover:bg-indigo-500/5 transition-all group"
              >
                <span class="flex items-center gap-2">
                  <span class="text-gray-600 group-hover:text-indigo-500 font-bold">
                    #
                  </span>
                  {tag}
                </span>
                <span class="text-xs bg-gray-900 text-gray-500 px-2 py-0.5 rounded-md border border-gray-800 group-hover:border-indigo-500/20 group-hover:text-indigo-400">
                  {count}
                </span>
              </a>
            );
          })
        }
      </nav>
    </aside>

    <div class="flex-grow w-full space-y-14">
      {
        allTags.map((tag) => {
          const currentTagPosts = sortedPosts.filter((post) =>
            post.data.tags.includes(tag),
          );

          return (
            <section id={`category-${tag}`} class="scroll-mt-24">
              <div class="flex items-center gap-3 mb-6">
                <div class="w-1.5 h-6 bg-gradient-to-b from-indigo-500 to-cyan-500 rounded-full" />
                <h2 class="text-2xl font-black text-white tracking-tight flex items-center gap-2">
                  {tag}
                  <span class="text-xs font-normal text-gray-500 bg-gray-900 px-2 py-1 border border-gray-800 rounded-md">
                    {currentTagPosts.length} 篇
                  </span>
                </h2>
              </div>

              <div class="w-full space-y-4">
                {currentTagPosts.map((post) => (
                  <Card
                    title={post.data.title}
                    description={post.data.description}
                    href={`/posts/${post.id}`}
                    tag={post.data.tags[0]}
                  />
                ))}
              </div>
            </section>
          );
        })
      }
    </div>
  </div>
</BaseLayout>

<style is:global>
  html {
    scroll-behavior: smooth;
  }
</style>
