---
// src/pages/posts/[id].astro
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render, type CollectionEntry } from "astro:content";

// 1. 静态路由声明
export async function getStaticPaths() {
  // 显式指定只抓取 blog 集合
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

// 2. 显式定义 Props 类型，防止 TypeScript 跑偏
interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;

// 3. 安全解析 Markdown
const { Content } = await render(post);
---

<BaseLayout title={post.data.title}>
  <article class="max-w-2xl mx-auto py-8">
    <header class="mb-8 pb-4 border-b border-gray-800">
      <h1
        class="text-3xl sm:text-4xl font-extrabold text-white mb-4 leading-tight"
      >
        {post.data.title}
      </h1>
      <p class="text-sm text-gray-500">
        发布于: {post.data.pubDate.toLocaleDateString("zh-CN")}
      </p>
    </header>

    <div class="markdown-body w-full">
      <Content />
    </div>
  </article>
</BaseLayout>

<style is:global>
  .markdown-body {
    color: #e5e7eb !important;
    font-size: 1.125rem;
    line-height: 1.8;
  }
  .markdown-body h2 {
    font-size: 1.75rem;
    font-weight: 700;
    color: #ffffff !important;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    border-bottom: 1px solid #1f2937;
    padding-bottom: 0.5rem;
  }
  .markdown-body p {
    margin-bottom: 1.5rem;
  }
  .markdown-body ul {
    list-style-type: disc !important;
    padding-left: 1.5rem !important;
    margin-bottom: 1.5rem;
  }
  .markdown-body li {
    margin-bottom: 0.5rem;
  }
</style>
